{
  "name": "puzzle-canvas",
  "version": "1.2.0",
  "private": true,
  "description": "无限画布，粘贴网址、图片、视频即可收藏",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:server": "bun run --hot server/index.ts",
    "dev:all": "bash scripts/start.sh",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:server": "bun test server/"
  },
  "dependencies": {
    "@ricons/antd": "^0.13.0",
    "@ricons/fluent": "^0.13.0",
    "@ricons/utils": "^0.1.6",
    "@xyflow/react": "^12.11.0",
    "bcryptjs": "^3.0.3",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.23",
    "jsonwebtoken": "^9.0.3",
    "lucide-react": "^1.17.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@eslint/js": "^10.0.1",
    "@rolldown/plugin-babel": "^0.2.3",
    "@types/babel__core": "^7.20.5",
    "@types/bcryptjs": "^3.0.0",
    "@types/bun": "^1.3.14",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.9.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "babel-plugin-react-compiler": "^1.0.0",
    "better-sqlite3": "^12.10.0",
    "drizzle-kit": "^0.31.10",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "jsdom": "^29.1.1",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12",
    "vitest": "^4.1.8"
  }
